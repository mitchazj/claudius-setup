---
# Template for ansible/vault/secrets.yml (which is committed ONLY encrypted).
#
# To create the real thing:
#   1. Create a 1Password item "claudius-setup ansible vault" with a strong
#      generated password.
#   2. cp secrets.yml.example secrets.yml && $EDITOR secrets.yml
#   3. ansible-vault encrypt secrets.yml --vault-password-file ../../scripts/vault-pass.sh
#   4. git add secrets.yml   (safe: it is now an encrypted blob)
#
# Verify before committing: `head -1 secrets.yml` must read $ANSIBLE_VAULT;1.1;AES256

# Reusable, expiring auth key from https://login.tailscale.com/admin/settings/keys
tailscale_authkey: "tskey-auth-REPLACE-ME"
